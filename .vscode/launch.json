{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug minbot (CLI)",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "node",
      "runtimeArgs": ["--env-file=.env", "--import", "tsx/esm", "--inspect"],
      "args": ["src/index.ts"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**", "**/node_modules/**"]
    }
  ]
}
