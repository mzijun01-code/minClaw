{
  "name": "minbot",
  "version": "0.1.0",
  "description": "A minimal but powerful AI agent in Node.js, powered by LangChain",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "start": "node --env-file=.env dist/index.js",
    "dev": "node --env-file=.env --import tsx/esm src/index.ts",
    "dev:debug": "MINBOT_DEBUG=1 node --env-file=.env --import tsx/esm src/index.ts",
    "build": "tsc && cp -r src/skills dist/skills",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@langchain/core": "^0.3.0",
    "@langchain/openai": "^0.3.0",
    "@larksuiteoapi/node-sdk": "^1.59.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@slack/socket-mode": "^2.0.5",
    "@slack/web-api": "^7.14.1",
    "@types/ws": "^8.18.1",
    "axios": "^1.7.0",
    "chalk": "^5.3.0",
    "cheerio": "^1.0.0",
    "dotenv": "^16.4.0",
    "node-cron": "^3.0.0",
    "ora": "^8.1.0",
    "socket.io-client": "^4.8.3",
    "telegraf": "^4.16.3",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/node-cron": "^3.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "bin": {
    "minbot": "dist/index.js"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
